{
  "expo": {
    "name": "front",
    "slug": "front",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.jpeg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.cryptobit",
      "supportsTablet": true,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Necesitamos usar Face ID para desbloquear tu cartera de forma segura.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.cryptobit.front",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.jpeg",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/logo.jpeg"
    },
    "extra": {
      "eas": {
        "projectId": "eb4d57e2-0523-471f-93f0-e3a19633bea4"
      }
    }
  }
}
